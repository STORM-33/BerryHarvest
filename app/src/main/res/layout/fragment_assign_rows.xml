<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Верхняя часть: ввод данных и основные кнопки -->
    <LinearLayout
        android:id="@+id/assignWorkerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="start"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Ряд: метка и ввод номера ряда -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ряд: "
                android:textSize="16sp" />

            <EditText
                android:id="@+id/rowEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Номер ряду"
                android:inputType="number"
                android:maxLength="3"
                android:layout_marginEnd="16dp" />
        </LinearLayout>

        <!-- Выбор работника через спиннер -->
        <com.example.berryharvest.ui.common.SearchableSpinnerView
            android:id="@+id/workerSearchView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Кнопка "Призначити" (с накладывающимся ProgressBar) -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/assignButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Призначити" />

            <ProgressBar
                android:id="@+id/loadingProgressBar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:visibility="gone" />
        </FrameLayout>

    </LinearLayout>

    <!-- Список назначений (например, список рядов) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/assignmentsRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/assignWorkerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/clearAllRowsButton" />

    <!-- Кнопка удаления внизу страницы, на всю ширину -->
    <Button
        android:id="@+id/clearAllRowsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Видалити всі ряди"
        android:backgroundTint="#F44336"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>



