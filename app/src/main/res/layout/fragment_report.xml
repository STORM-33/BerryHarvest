<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.report.ReportFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/card_margin">

            <!-- Overall Statistics Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/card_margin"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊 Загальна статистика"
                        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                        android:textSize="@dimen/section_title_text_size"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/section_title_margin" />

                    <!-- Overall stats - responsive grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- First row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="@dimen/stats_row_margin">

                            <!-- Total trays -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="@dimen/stats_item_padding"
                                android:background="?android:attr/selectableItemBackground">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Всього збрано лотків"
                                    android:textSize="@dimen/stats_label_text_size"
                                    android:textColor="@color/text_secondary"
                                    android:gravity="center"
                                    android:maxLines="2"
                                    android:ellipsize="end" />

                                <TextView
                                    android:id="@+id/totalTraysTextView"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Large"
                                    android:textStyle="bold"
                                    android:textColor="@color/success_color"
                                    android:layout_marginTop="@dimen/stats_value_margin" />
                            </LinearLayout>

                            <!-- Total paid -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="@dimen/stats_item_padding"
                                android:background="?android:attr/selectableItemBackground">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Всього оплачено"
                                    android:textSize="@dimen/stats_label_text_size"
                                    android:textColor="@color/text_secondary"
                                    android:gravity="center"
                                    android:maxLines="2"
                                    android:ellipsize="end" />

                                <TextView
                                    android:id="@+id/totalPaidTextView"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0.00₴"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Large"
                                    android:textStyle="bold"
                                    android:textColor="@color/warning_color"
                                    android:layout_marginTop="@dimen/stats_value_margin" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Second row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Average workers per day -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="@dimen/stats_item_padding"
                                android:background="?android:attr/selectableItemBackground">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Середня кількість працівників"
                                    android:textSize="@dimen/stats_label_text_size"
                                    android:textColor="@color/text_secondary"
                                    android:gravity="center"
                                    android:maxLines="2"
                                    android:ellipsize="end" />

                                <TextView
                                    android:id="@+id/avgWorkersPerDayTextView"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0.0"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Large"
                                    android:textStyle="bold"
                                    android:textColor="@color/info_color"
                                    android:layout_marginTop="@dimen/stats_value_margin" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Today's Statistics Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/card_margin"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅 Статистика за сьогодні"
                        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                        android:textSize="@dimen/section_title_text_size"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/section_title_margin" />

                    <!-- Today's stats - responsive grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- First row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="@dimen/stats_row_margin">

                            <!-- Today trays -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="@dimen/stats_item_padding"
                                android:background="?android:attr/selectableItemBackground">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Лотків сьогодні"
                                    android:textSize="@dimen/stats_label_text_size"
                                    android:textColor="@color/text_secondary"
                                    android:gravity="center"
                                    android:maxLines="2"
                                    android:ellipsize="end" />

                                <TextView
                                    android:id="@+id/todayTraysTextView"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Large"
                                    android:textStyle="bold"
                                    android:textColor="@color/success_color"
                                    android:layout_marginTop="@dimen/stats_value_margin" />
                            </LinearLayout>

                            <!-- Today to pay -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="@dimen/stats_item_padding"
                                android:background="?android:attr/selectableItemBackground">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="До оплати сьогодні"
                                    android:textSize="@dimen/stats_label_text_size"
                                    android:textColor="@color/text_secondary"
                                    android:gravity="center"
                                    android:maxLines="2"
                                    android:ellipsize="end" />

                                <TextView
                                    android:id="@+id/todayToPayTextView"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0.00₴"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Large"
                                    android:textStyle="bold"
                                    android:textColor="@color/warning_color"
                                    android:layout_marginTop="@dimen/stats_value_margin" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Second row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Active workers today -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="@dimen/stats_item_padding"
                                android:background="?android:attr/selectableItemBackground">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Активних працівників"
                                    android:textSize="@dimen/stats_label_text_size"
                                    android:textColor="@color/text_secondary"
                                    android:gravity="center"
                                    android:maxLines="2"
                                    android:ellipsize="end" />

                                <TextView
                                    android:id="@+id/activeWorkersTodayTextView"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textAppearance="@style/TextAppearance.AppCompat.Large"
                                    android:textStyle="bold"
                                    android:textColor="@color/accent_color"
                                    android:layout_marginTop="@dimen/stats_value_margin" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Worker Performance Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="👥 Продуктивність працівників"
                        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
                        android:textSize="@dimen/section_title_text_size"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/small_margin" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="(сортування за загальною кількістю)"
                        android:textSize="@dimen/caption_text_size"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/section_title_margin" />

                    <!-- No table header - just use RecyclerView with card-based design -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/workerStatsRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:itemCount="5"
                        tools:listitem="@layout/item_worker_stats" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Loading indicator -->
            <ProgressBar
                android:id="@+id/loadingProgressBar"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/card_margin"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>